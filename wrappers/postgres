#!/usr/bin/env bash

# shellcheck disable=SC1091,SC2155
set -euo pipefail

# Resolve script path when invoked through symlink
script_path="${BASH_SOURCE[0]}"
while [[ -L "$script_path" ]]; do
  script_dir="$(CDPATH='' cd -- "$(dirname -- "$script_path")" && pwd)"
  link_target="$(readlink "$script_path")"

  if [[ "$link_target" == /* ]]; then
    script_path="$link_target"
  else
    script_path="$script_dir/$link_target"
  fi
done

readonly LIB_DIR="$(CDPATH='' cd -- "$(dirname -- "$script_path")" && pwd)"
readonly INSTALL_DIR="$(CDPATH='' cd -- "$LIB_DIR/.." && pwd)"

if [[ ! -f "$INSTALL_DIR/manifest" ]]; then
  echo "mise-db manifest not found: $INSTALL_DIR/manifest" >&2
  exit 1
fi

source "$INSTALL_DIR/manifest"
source "$LIB_DIR/context.sh"

: "${PGUSER:?PGUSER is required}"
: "${PGPASS:?PGPASS is required}"

case "${ADAPTER:-}" in
  apple)
    source "$LIB_DIR/apple.sh"
    ;;
  docker)
    source "$LIB_DIR/docker.sh"
    ;;
  *)
    echo "mise-db manifest has an unsupported adapter: ${ADAPTER:-missing}" >&2
    echo "Force-reinstall this tool to create a valid manifest." >&2
    exit 1
    ;;
esac

readonly CONTAINER="$(container_name)"
readonly NETWORK="mise-db"

ensure_data_dir() {
  local data
  data="$(data_dir)"
  mkdir -p "$data"
}

create_server_container() {
  ensure_image "$IMAGE"
  ensure_network "$NETWORK"
  ensure_data_dir

  if [[ "$ADAPTER" == "apple" ]]; then
    container create \
      --name "$CONTAINER" \
      --network "$NETWORK" \
      --volume "$(data_dir):/var/lib/postgresql/data" \
      --env POSTGRES_DB="$PGUSER" \
      --env POSTGRES_USER="$PGUSER" \
      --env POSTGRES_PASSWORD="$PGPASS" \
      --env PGDATA=/var/lib/postgresql/data/pgdata \
      "$IMAGE" >/dev/null
  else
    docker create \
      --name "$CONTAINER" \
      --network "$NETWORK" \
      --volume "$(data_dir):/var/lib/postgresql/data" \
      --env POSTGRES_DB="$PGUSER" \
      --env POSTGRES_USER="$PGUSER" \
      --env POSTGRES_PASSWORD="$PGPASS" \
      --env PGDATA=/var/lib/postgresql/data/pgdata \
      --health-cmd "pg_isready -U $PGUSER" \
      --health-interval 1s \
      --health-timeout 5s \
      --health-retries 60 \
      "$IMAGE" >/dev/null
  fi
}

start_server() {
  require_adapter

  if ! container_exists "$CONTAINER"; then
    create_server_container
  fi

  if ! container_running "$CONTAINER"; then
    if [[ "$ADAPTER" == "apple" ]]; then
      container start "$CONTAINER" >/dev/null
    else
      docker start "$CONTAINER" >/dev/null
    fi
  fi

  container_ready "$CONTAINER" 60 "$PGUSER"
  printf 'PostgreSQL %s running as %s on %s network %s\n' "$VERSION" "$CONTAINER" "$ADAPTER" "$NETWORK"
}

stop_server() {
  require_adapter

  if ! container_exists "$CONTAINER"; then
    echo "PostgreSQL container does not exist: $CONTAINER" >&2
    return 3
  fi

  if container_running "$CONTAINER"; then
    if [[ "$ADAPTER" == "apple" ]]; then
      container stop "$CONTAINER" >/dev/null
    else
      docker stop "$CONTAINER" >/dev/null
    fi
  fi

  if [[ "$ADAPTER" == "apple" ]]; then
    container delete "$CONTAINER" >/dev/null
  else
    docker rm "$CONTAINER" >/dev/null
  fi
}

status_server() {
  require_adapter
  container_status "$CONTAINER" "PostgreSQL" "$PGUSER"
}

reload_server() {
  require_adapter

  if ! container_running "$CONTAINER"; then
    echo "PostgreSQL container is not running: $CONTAINER" >&2
    return 3
  fi

  if [[ "$ADAPTER" == "apple" ]]; then
    container exec "$CONTAINER" pg_ctl reload -D "${PGDATA:-/var/lib/postgresql/data/pgdata}"
  else
    docker exec "$CONTAINER" pg_ctl reload -D "${PGDATA:-/var/lib/postgresql/data/pgdata}"
  fi
}

run_client() {
  local client="$1"
  shift

  require_adapter
  ensure_image "$IMAGE"
  ensure_network "$NETWORK"

  case "${1:-}" in
    --help|--version|-V)
      if [[ "$ADAPTER" == "apple" ]]; then
        container run --rm "$IMAGE" "$client" "$@"
      else
        docker run --rm "$IMAGE" "$client" "$@"
      fi
      return
      ;;
  esac

  if [[ "$ADAPTER" == "apple" ]]; then
    container run --rm "$(container_tty_args)" \
      --network "$NETWORK" \
      --volume "$PWD:$PWD" \
      --workdir "$PWD" \
      --env PGPASSWORD="$PGPASS" \
      "$IMAGE" "$client" -h "$(container_ip "$CONTAINER")" -U "$PGUSER" "$@"
  else
    docker run --rm "$(container_tty_args)" \
      --network "$NETWORK" \
      --volume "$PWD:$PWD" \
      --workdir "$PWD" \
      --env PGPASSWORD="$PGPASS" \
      "$IMAGE" "$client" -h "$CONTAINER" -U "$PGUSER" "$@"
  fi
}

pg_ctl_wrapper() {
  local action="${1:-status}"
  shift || true

  case "$action" in
    start)
      start_server
      ;;
    stop)
      stop_server "$@"
      ;;
    status)
      status_server
      ;;
    restart)
      stop_server "$@" || true
      start_server
      ;;
    reload)
      reload_server
      ;;
    *)
      echo "mise-db pg_ctl supports start, stop, status, restart, and reload." >&2
      echo "Unsupported pg_ctl action: $action" >&2
      exit 2
      ;;
  esac
}

command_name="$(basename "$0")"

case "$command_name" in
  pg_ctl)
    pg_ctl_wrapper "$@"
    ;;
  postgres)
    pg_ctl_wrapper start
    if [[ "$ADAPTER" == "apple" ]]; then
      container logs --follow "$CONTAINER"
    else
      docker logs -f "$CONTAINER"
    fi
    ;;
  psql|pg_dump|pg_restore|createdb|dropdb|createuser|dropuser)
    run_client "$command_name" "$@"
    ;;
  *)
    echo "unsupported mise-db PostgreSQL command: $command_name" >&2
    exit 2
    ;;
esac
